generator client {
  provider = "prisma-client"
  output  = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                String         @id @default(uuid())
  businessName      String
  planType          String         @default("free")
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  commissionPorcent Decimal        @default(1.00) @db.Decimal(10, 2)
  deliveryPrice     Decimal        @default(0.00) @db.Decimal(10, 2)
  address           String         @default("Direccion no configurada")
  daysOverdue       Int            @default(0)
  email             String?        @unique
  nextBillingDate   DateTime?
  suscriptionStatus String         @default("ACTIVE")
  apiConfig         ApiConfig?
  businessHours     BusinessHour[]
  combos            Combo[]
  invoices          Invoice[]
  orders            Order[]
  products          Product[]
  sessions          Session[]
  specialDates      SpecialDate[]
  users             User[]
}

model ApiConfig {
  tenantId          String  @id
  whatsappToken     String
  whatsappPhoneId   String
  paymentPrivateKey String?
  webhookSecret     String?
  mpUserId          String?
  refreshToken      String?
  tenant            Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Product {
  id          String      @id @default(uuid())
  tenantId    String
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  comboItems  ComboItem[]
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Combo {
  id            String      @id @default(uuid())
  tenantId      String
  name          String
  type          String
  discountValue Decimal?    @db.Decimal(10, 2)
  isActive      Boolean     @default(true)
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         ComboItem[]
}

model ComboItem {
  comboId   String
  productId String
  quantity  Int     @default(1)
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([comboId, productId])
}

model Session {
  customerPhone   String
  tenantId        String
  currentState    String         @default("GREETING")
  isBotActive     Boolean        @default(true)
  fallbackCount   Int            @default(0)
  chatHistory     Json           @default("[]")
  pendingOrder    Json           @default("{}")
  lastInteraction DateTime       @default(now()) @updatedAt
  deliveryAddress String         @default("")
  deliveryMethod  DeliveryMethod @default(PICKUP)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([customerPhone, tenantId])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Order {
  id               String         @id @default(uuid())
  tenantId         String
  customerPhone    String
  items            Json
  totalAmount      Decimal        @db.Decimal(10, 2)
  status           String         @default("PENDING")
  paymentProvider  String?
  paymentId        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @default(now()) @updatedAt
  commissionAmount Decimal?       @db.Decimal(10, 2)
  customerName     String?
  deliveryAddress  String?
  deliveryAmount   Decimal        @default(0.00) @db.Decimal(10, 2)
  deliveryMethod   DeliveryMethod @default(PICKUP)
  orderNumber      Int            @default(autoincrement())
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BusinessHour {
  id        String @id @default(uuid())
  dayOfWeek Int
  openTime  String
  closeTime String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, dayOfWeek])
}

model SpecialDate {
  id        String   @id @default(uuid())
  date      DateTime
  isOpen    Boolean  @default(false)
  openTime  String?
  closeTime String?
  comment   String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
}

model Invoice {
  id        String   @id @default(uuid())
  tenantId  String
  amount    Decimal  @db.Decimal(10, 2)
  dueDate   DateTime
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

enum DeliveryMethod {
  PICKUP
  DELIVERY
}
